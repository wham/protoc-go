#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TESTS_DIR="$PROJECT_DIR/testdata"
RESULTS_DIR="$PROJECT_DIR/results"

# Source protoc location
source "$SCRIPT_DIR/find-protoc"

# Build tools
PROTOC_GO="$PROJECT_DIR/cmd/protoc-go/protoc-go"
PROTOC_GEN_DUMP="$PROJECT_DIR/tools/protoc-gen-dump/protoc-gen-dump"

# Parse flags
SUMMARY_ONLY=false
for arg in "$@"; do
  case "$arg" in
    --summary) SUMMARY_ONLY=true ;;
  esac
done

# -- setup ---------------------------------------------------------------

echo "Building protoc-go..."
(cd "$PROJECT_DIR" && go build -o "$PROTOC_GO" ./cmd/protoc-go/)

echo "Building protoc-gen-dump..."
(cd "$PROJECT_DIR" && go build -o "$PROTOC_GEN_DUMP" ./tools/protoc-gen-dump/)

echo "Using C++ protoc: $PROTOC ($(protoc --version))"
echo ""

# -- test loop ------------------------------------------------------------

rm -rf "$RESULTS_DIR"
mkdir -p "$RESULTS_DIR"

# Millisecond timer helper
now_ms() {
  perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000'
}

run_test() {
  local test_name="$1"
  local test_dir="$2"
  local expected_dir="$RESULTS_DIR/$test_name/expected"
  local actual_dir="$RESULTS_DIR/$test_name/actual"
  local result_file="$RESULTS_DIR/$test_name/result.txt"
  local failure_file="$RESULTS_DIR/$test_name/failure.txt"

  mkdir -p "$expected_dir" "$actual_dir"

  # Collect proto files
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi

  # Convert to relative paths
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # Run C++ protoc with protoc-gen-dump (expected output)
  cpp_error_file="$RESULTS_DIR/$test_name/cpp_error.txt"
  cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$expected_dir" \
    --dump_opt="$expected_dir" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$cpp_error_file" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))

  # Run Go protoc-go with protoc-gen-dump (actual output)
  go_error_file="$RESULTS_DIR/$test_name/go_error.txt"
  go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$actual_dir" \
    --dump_opt="$actual_dir" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$go_error_file" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))

  # If both failed, compare error messages
  if [ "$cpp_ok" = false ] && [ "$go_ok" = false ]; then
    cpp_err=$(cat "$cpp_error_file" 2>/dev/null || echo "")
    go_err=$(cat "$go_error_file" 2>/dev/null || echo "")

    cpp_err_normalized=$(echo "$cpp_err" | sed 's/[[:space:]]*$//' | sed '/^$/d')
    go_err_normalized=$(echo "$go_err" | sed 's/[[:space:]]*$//' | sed '/^$/d')

    if [ "$cpp_err_normalized" = "$go_err_normalized" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      {
        echo "error mismatch"
        echo "--- C++ protoc error"
        echo "+++ Go protoc-go error"
        diff -u \
          <(echo "$cpp_err" | sed 's/[[:space:]]*$//') \
          <(echo "$go_err" | sed 's/[[:space:]]*$//') \
          2>&1 || true
      } > "$failure_file"
    fi
    return
  fi

  # If one succeeded and the other failed
  if [ "$cpp_ok" != "$go_ok" ]; then
    echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
    if [ "$cpp_ok" = true ]; then
      {
        echo "Go protoc-go failed but C++ protoc succeeded"
        echo ""
        echo "Go error:"
        cat "$go_error_file" 2>/dev/null || echo "(no error output)"
      } > "$failure_file"
    else
      {
        echo "C++ protoc failed but Go protoc-go succeeded"
        echo ""
        echo "C++ error:"
        cat "$cpp_error_file" 2>/dev/null || echo "(no error output)"
      } > "$failure_file"
    fi
    return
  fi

  # Compare outputs — use summary.txt for human-readable diffs
  diff_output=""

  # Compare summary files
  if [ -f "$expected_dir/summary.txt" ] && [ -f "$actual_dir/summary.txt" ]; then
    diff_output=$(diff -u "$expected_dir/summary.txt" "$actual_dir/summary.txt" 2>&1) || true
  fi

  # If summaries match, also verify binary output matches
  if [ -z "$diff_output" ] && [ -f "$expected_dir/request.pb" ] && [ -f "$actual_dir/request.pb" ]; then
    if ! cmp -s "$expected_dir/request.pb" "$actual_dir/request.pb"; then
      diff_output="Binary CodeGeneratorRequest differs (summary matched but binary did not)"
    fi
  fi

  if [ -z "$diff_output" ]; then
    echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
  else
    echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
    echo "$diff_output" > "$failure_file"
  fi
}

# Launch all tests in parallel
PIDS=()
TEST_NAMES=()

for test_dir in "$TESTS_DIR"/*/; do
  if [ -d "$test_dir" ]; then
    test_name="$(basename "$test_dir")"
    run_test "$test_name" "$test_dir" &
    PIDS+=($!)
    TEST_NAMES+=("$test_name")
  fi
done

# Wait for all tests to finish
for pid in "${PIDS[@]}"; do
  wait "$pid" || true
done

# -- collect results ------------------------------------------------------

PASS=0
FAIL=0
ERRORS=""
CPP_TOTAL_MS=0
GO_TOTAL_MS=0

for test_name in $(echo "${TEST_NAMES[@]}" | tr ' ' '\n' | sort); do
  result_file="$RESULTS_DIR/$test_name/result.txt"
  failure_file="$RESULTS_DIR/$test_name/failure.txt"

  if [ ! -f "$result_file" ]; then
    continue
  fi

  read -r status cpp_ms go_ms < "$result_file"
  CPP_TOTAL_MS=$(( CPP_TOTAL_MS + cpp_ms ))
  GO_TOTAL_MS=$(( GO_TOTAL_MS + go_ms ))

  if [ "$status" = "PASS" ]; then
    PASS=$((PASS + 1))
    if [ "$SUMMARY_ONLY" = false ]; then
      echo "PASS $test_name"
    fi
  else
    FAIL=$((FAIL + 1))
    if [ "$SUMMARY_ONLY" = false ]; then
      echo "FAIL $test_name"
      if [ -f "$failure_file" ]; then
        head -40 "$failure_file"
        echo ""
      fi
    fi
    if [ -f "$failure_file" ]; then
      ERRORS="$ERRORS\n--- $test_name ---\n$(cat "$failure_file")"
    fi
  fi
done

# -- summary --------------------------------------------------------------

TOTAL=$((PASS + FAIL))
echo ""
echo "Results: $PASS/$TOTAL passed, $FAIL/$TOTAL failed"

if [ "$CPP_TOTAL_MS" -gt 0 ] && [ "$GO_TOTAL_MS" -gt 0 ]; then
  CPP_SEC=$(echo "scale=1; $CPP_TOTAL_MS / 1000" | bc)
  GO_SEC=$(echo "scale=1; $GO_TOTAL_MS / 1000" | bc)
  echo "Performance: C++ protoc ${CPP_SEC}s, Go protoc-go ${GO_SEC}s"
fi

if [ "$FAIL" -gt 0 ]; then
  if [ "$SUMMARY_ONLY" = true ]; then
    echo ""
    echo "Failing tests:"
    echo -e "$ERRORS" | grep "^--- " | sed 's/^--- /  /' | sed 's/ ---$//'
  fi
  exit 1
fi
