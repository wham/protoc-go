# -- partial generation test -----------------------------------------------
# Tests that only a subset of .proto files are listed for generation.

run_partial_gen_test() {
  local test_name="$1"
  local test_dir="$2"
  local gen_file="$3"
  local full_name="partial@${test_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local expected_dir="$result_dir/expected"
  local actual_dir="$result_dir/actual"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$expected_dir" "$actual_dir"

  # Run C++ protoc — only gen_file listed for generation, but -I includes the dir
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$expected_dir" --dump_opt="$expected_dir" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    "$gen_file") 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$actual_dir" --dump_opt="$actual_dir" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    "$gen_file") 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  if [ -f "$result_dir/both_ok.txt" ]; then
    local diff_output=""

    if [ -f "$expected_dir/summary.txt" ] && [ -f "$actual_dir/summary.txt" ]; then
      diff_output=$(diff -u "$expected_dir/summary.txt" "$actual_dir/summary.txt" 2>&1) || true
    fi

    if [ -z "$diff_output" ] && [ -f "$expected_dir/request.pb" ] && [ -f "$actual_dir/request.pb" ]; then
      if ! cmp -s "$expected_dir/request.pb" "$actual_dir/request.pb"; then
        diff_output="Binary CodeGeneratorRequest differs (partial gen)"
      fi
    fi

    if [ -z "$diff_output" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      echo "$diff_output" > "$failure_file"
    fi
  fi
}

# Test: generate only main.proto (dep.proto is a dependency, not a generation target)
run_partial_gen_test "331_only_main" "$TESTS_DIR/331_partial_generation" "main.proto" &
PIDS+=($!)
TEST_NAMES+=("partial@331_only_main")

# Test: generate only dep.proto (standalone, no imports needed)
run_partial_gen_test "331_only_dep" "$TESTS_DIR/331_partial_generation" "dep.proto" &
PIDS+=($!)
TEST_NAMES+=("partial@331_only_dep")

# -- stdin/stdout tests (decode_raw with real binary) ----------------------

run_decode_raw_test() {
  local test_name="$1"
  local binary_hex="$2"
  local full_name="stdin@${test_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$result_dir"

  # Convert hex to binary
  local binary_file="$result_dir/input.bin"
  echo "$binary_hex" | xxd -r -p > "$binary_file"

  # Run C++ protoc --decode_raw
  local cpp_exit=0
  "$PROTOC" --decode_raw < "$binary_file" >"$result_dir/cpp_stdout.txt" 2>"$result_dir/cpp_stderr.txt" || cpp_exit=$?

  # Run Go protoc-go --decode_raw
  local go_exit=0
  "$PROTOC_GO" --decode_raw < "$binary_file" >"$result_dir/go_stdout.txt" 2>"$result_dir/go_stderr.txt" || go_exit=$?

  if [ "$cpp_exit" != "$go_exit" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "exit code mismatch: C++ protoc=$cpp_exit, Go protoc-go=$go_exit"
      echo "--- C++ stderr ---"
      cat "$result_dir/cpp_stderr.txt"
      echo "+++ Go stderr +++"
      cat "$result_dir/go_stderr.txt"
    } > "$failure_file"
    return
  fi

  local cpp_stdout go_stdout
  cpp_stdout=$(cat "$result_dir/cpp_stdout.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')
  go_stdout=$(cat "$result_dir/go_stdout.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')

  if [ "$cpp_stdout" != "$go_stdout" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "stdout mismatch"
      diff -u "$result_dir/cpp_stdout.txt" "$result_dir/go_stdout.txt" 2>&1 || true
    } > "$failure_file"
    return
  fi

  local cpp_stderr go_stderr
  cpp_stderr=$(cat "$result_dir/cpp_stderr.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')
  go_stderr=$(cat "$result_dir/go_stderr.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')

  if [ "$cpp_stderr" != "$go_stderr" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "stderr mismatch"
      diff -u "$result_dir/cpp_stderr.txt" "$result_dir/go_stderr.txt" 2>&1 || true
    } > "$failure_file"
    return
  fi

  echo "PASS 0 0" > "$result_file"
}

# Hex-encoded protobuf binary data for decode_raw tests:
#   simple: field 1 (string "hello"), field 2 (varint 42)
#   nested: field 1 (string "outer"), field 2 (embedded msg with field 1 = "inner")
#   multi_type: field 1 (varint 150), field 2 (string "test"), field 3 (fixed32 0x12345678), field 5 (fixed64)
#   empty: empty input (zero bytes)
#   corrupt: truncated varint
#   single_quote: field 1 (string "'") — tests cEscape of single quote char
STDIN_TESTS=(
  "decode_raw_simple|0a0568656c6c6f102a"
  "decode_raw_nested|0a056f7574657212070a05696e6e6572"
  "decode_raw_multi_type|0896011204746573741d78563412"
  "decode_raw_empty|"
  "decode_raw_corrupt|08"
  "decode_raw_single_quote|0a0127"
  "decode_raw_group|0b0a0568656c6c6f0c"
  "decode_raw_overflow_varint|0880808080808080808002"
)

for stdin_spec in "${STDIN_TESTS[@]}"; do
  IFS='|' read -r stdin_name stdin_hex <<< "$stdin_spec"
  run_decode_raw_test "$stdin_name" "$stdin_hex" &
  PIDS+=($!)
  TEST_NAMES+=("stdin@${stdin_name}")
done

# -- decode tests ----------------------------------------------------------
# Compare --decode=TYPE output between C++ protoc and Go protoc-go.

run_decode_test() {
  local test_name="$1"
  local proto_dir="$2"
  local msg_type="$3"
  local binary_hex="$4"
  local full_name="decode@${test_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$result_dir"

  local binary_file="$result_dir/input.bin"
  echo "$binary_hex" | xxd -r -p > "$binary_file"

  local proto_files
  proto_files=$(find "$proto_dir" -maxdepth 1 -name "*.proto" -exec basename {} \; | sort)

  local cpp_exit=0
  (cd "$proto_dir" && "$PROTOC" -I. --decode="$msg_type" $proto_files < "$binary_file") \
    >"$result_dir/cpp_stdout.txt" 2>"$result_dir/cpp_stderr.txt" || cpp_exit=$?

  local go_exit=0
  (cd "$proto_dir" && "$PROTOC_GO" -I. --decode="$msg_type" $proto_files < "$binary_file") \
    >"$result_dir/go_stdout.txt" 2>"$result_dir/go_stderr.txt" || go_exit=$?

  if [ "$cpp_exit" != "$go_exit" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "exit code mismatch: C++ protoc=$cpp_exit, Go protoc-go=$go_exit"
      echo "--- C++ stderr ---"
      cat "$result_dir/cpp_stderr.txt"
      echo "+++ Go stderr +++"
      cat "$result_dir/go_stderr.txt"
    } > "$failure_file"
    return
  fi

  local cpp_stdout go_stdout
  cpp_stdout=$(cat "$result_dir/cpp_stdout.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')
  go_stdout=$(cat "$result_dir/go_stdout.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')

  if [ "$cpp_stdout" != "$go_stdout" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "stdout mismatch"
      diff -u "$result_dir/cpp_stdout.txt" "$result_dir/go_stdout.txt" 2>&1 || true
    } > "$failure_file"
    return
  fi

  local cpp_stderr go_stderr
  cpp_stderr=$(cat "$result_dir/cpp_stderr.txt" | sed 's/^[EIWF][0-9][0-9][0-9][0-9] [0-9:.]* [0-9]* [^ ]*] //' | sed 's/[[:space:]]*$//' | sed '/^$/d')
  go_stderr=$(cat "$result_dir/go_stderr.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')

  if [ "$cpp_stderr" != "$go_stderr" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "stderr mismatch"
      diff -u "$result_dir/cpp_stderr.txt" "$result_dir/go_stderr.txt" 2>&1 || true
    } > "$failure_file"
    return
  fi

  echo "PASS 0 0" > "$result_file"
}

# Decode tests: name|proto_dir|message_type|hex_data
# 0801 = field 1 (varint) value 1 (COLOR_RED)
# 120568656c6c6f = field 2 (string) "hello"
DECODE_TESTS=(
  "enum_value|testdata/448_decode_enum|decodeenumtest.Painted|08011205776f726c64"
  "float_value|testdata/449_decode_float|decodefloat.Measurement|0dcdcccc3d1203666f6f"
  "neg_int64|testdata/450_decode_int64|decodeint64.Record|08ffffffffffffffffff0112026f6b"
  "double_integer|testdata/451_decode_double|decodedouble.Sample|09000000000000f03f12026f6b"
  "float_integer|testdata/452_decode_float_int|decodefloatint.Sample|0d000000401203666f6f"
  "packed_repeated|testdata/453_decode_packed|decodepacked.Numbers|0a0301020312026f6b"
  "extension_field|testdata/454_decode_extension|decodeext.Base|0a026869a0062a"
  "wrong_wire|testdata/455_decode_wrong_wire|decodewire.Record|0d2a00000012026f6b"
  "map_sort|testdata/456_decode_map_sort|decodemapsort.Config|0a0b0a0774696d656f7574101e0a0b0a07726574726965731003120474657374"
  "proto2_unknown_enum|testdata/457_decode_proto2_unknown_enum|decode_p2_enum.Record|086312026f6b"
  "edition_open_enum|testdata/458_decode_edition_open_enum|decodeeditionenum.Record|086312026f6b"
  "double_precision|testdata/459_decode_double_precision|decodedoubleprec.Sample|09020000000000004012026f6b"
  "oneof_dedup|testdata/460_decode_oneof_dedup|oneofdedup.Msg|0a0568656c6c6f102a1a026f6b"
  "dup_scalar|testdata/461_decode_dup_scalar|decodedup.Record|0801080212026f6b"
  "group_merge|testdata/462_decode_group_merge|decodegroupmerge.Record|0b0a0568656c6c6f0c0b102a0c12026f6b"
