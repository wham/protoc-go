#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TESTS_DIR="$PROJECT_DIR/testdata"
RESULTS_DIR="$PROJECT_DIR/results"

# Source protoc location
source "$SCRIPT_DIR/find-protoc"

# Build tools
PROTOC_GO="$PROJECT_DIR/cmd/protoc-go/protoc-go"
PROTOC_GEN_DUMP="$PROJECT_DIR/tools/protoc-gen-dump/protoc-gen-dump"

# Parse flags
SUMMARY_ONLY=false
for arg in "$@"; do
  case "$arg" in
    --summary) SUMMARY_ONLY=true ;;
  esac
done

# -- setup ---------------------------------------------------------------

echo "Building protoc-go..."
(cd "$PROJECT_DIR" && go build -o "$PROTOC_GO" ./cmd/protoc-go/)

echo "Building protoc-gen-dump..."
(cd "$PROJECT_DIR" && go build -o "$PROTOC_GEN_DUMP" ./tools/protoc-gen-dump/)

echo "Using C++ protoc: $PROTOC ($($PROTOC --version))"
echo ""

# -- profiles -------------------------------------------------------------
# Each profile defines a different way to invoke protoc on a .proto test case.
# Format: profile_name|mode|extra_flags
# mode=plugin: uses protoc-gen-dump, compares CodeGeneratorRequest
# mode=descriptor: uses --descriptor_set_out, compares binary output
# mode=cli: special CLI-level tests (no .proto files)

PROFILES=(
  "plugin|plugin|"
  "plugin_param|plugin|--dump_opt=test_option=value"
  "descriptor_set|descriptor|"
  "descriptor_set_src|descriptor|--include_source_info"
  "descriptor_set_full|descriptor|--include_imports --include_source_info"
  "descriptor_set_retain|descriptor|--retain_options"
  "multi_plugin|multi_plugin|"
  "multi_opt|multi_opt|"
  "plugin_descriptor|plugin_descriptor|"
  "colon_param|colon_param|"
)

# -- helpers --------------------------------------------------------------

rm -rf "$RESULTS_DIR"
mkdir -p "$RESULTS_DIR"

now_ms() {
  perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000'
}

# compare_results result_dir result_file failure_file cpp_elapsed go_elapsed
#   Checks cpp_ok/go_ok files and compares outputs.
compare_results() {
  local result_dir="$1"
  local result_file="$2"
  local failure_file="$3"
  local cpp_elapsed="$4"
  local go_elapsed="$5"
  local cpp_ok go_ok

  cpp_ok=$(cat "$result_dir/cpp_ok.txt")
  go_ok=$(cat "$result_dir/go_ok.txt")

  # If both failed, compare error messages
  if [ "$cpp_ok" = false ] && [ "$go_ok" = false ]; then
    local cpp_err go_err
    cpp_err=$(cat "$result_dir/cpp_error.txt" 2>/dev/null | sed 's/[[:space:]]*$//' | sed '/^$/d')
    go_err=$(cat "$result_dir/go_error.txt" 2>/dev/null | sed 's/[[:space:]]*$//' | sed '/^$/d')

    if [ "$cpp_err" = "$go_err" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      {
        echo "error mismatch"
        echo "--- C++ protoc error"
        echo "+++ Go protoc-go error"
        diff -u \
          <(cat "$result_dir/cpp_error.txt" | sed 's/[[:space:]]*$//') \
          <(cat "$result_dir/go_error.txt" | sed 's/[[:space:]]*$//') \
          2>&1 || true
      } > "$failure_file"
    fi
    return
  fi

  # If one succeeded and the other failed
  if [ "$cpp_ok" != "$go_ok" ]; then
    echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
    if [ "$cpp_ok" = true ]; then
      {
        echo "Go protoc-go failed but C++ protoc succeeded"
        echo ""
        echo "Go error:"
        cat "$result_dir/go_error.txt" 2>/dev/null || echo "(no error output)"
      } > "$failure_file"
    else
      {
        echo "C++ protoc failed but Go protoc-go succeeded"
        echo ""
        echo "C++ error:"
        cat "$result_dir/cpp_error.txt" 2>/dev/null || echo "(no error output)"
      } > "$failure_file"
    fi
    return
  fi

  echo "BOTH_OK" > "$result_dir/both_ok.txt"
}

# -- plugin profile test ---------------------------------------------------

run_plugin_test() {
  local test_name="$1"
  local test_dir="$2"
  local profile_name="$3"
  local extra_flags="$4"
  local full_name="${test_name}@${profile_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local expected_dir="$result_dir/expected"
  local actual_dir="$result_dir/actual"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$expected_dir" "$actual_dir"

  # Collect proto files
  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # The --dump_opt is used to pass the output directory AND any extra params.
  # protoc-gen-dump uses the parameter as the output directory.
  # For plugin_param profile, we append extra options but still need the dir as parameter.
  local dump_opt_cpp="$expected_dir"
  local dump_opt_go="$actual_dir"

  # Run C++ protoc
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$expected_dir" \
    --dump_opt="$dump_opt_cpp" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$actual_dir" \
    --dump_opt="$dump_opt_go" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  # If both succeeded, compare plugin outputs
  if [ -f "$result_dir/both_ok.txt" ]; then
    local diff_output=""

    # Compare summary files (human-readable)
    if [ -f "$expected_dir/summary.txt" ] && [ -f "$actual_dir/summary.txt" ]; then
      diff_output=$(diff -u "$expected_dir/summary.txt" "$actual_dir/summary.txt" 2>&1) || true
    fi

    # Also verify binary output matches exactly
    if [ -z "$diff_output" ] && [ -f "$expected_dir/request.pb" ] && [ -f "$actual_dir/request.pb" ]; then
      if ! cmp -s "$expected_dir/request.pb" "$actual_dir/request.pb"; then
        diff_output="Binary CodeGeneratorRequest differs (summary matched but binary did not)"
      fi
    fi

    if [ -z "$diff_output" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      echo "$diff_output" > "$failure_file"
    fi
  fi
}

# -- descriptor profile test -----------------------------------------------

run_descriptor_test() {
  local test_name="$1"
  local test_dir="$2"
  local profile_name="$3"
  local extra_flags="$4"
  local full_name="${test_name}@${profile_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$result_dir"

  # Collect proto files
  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  local expected_pb="$result_dir/expected.pb"
  local actual_pb="$result_dir/actual.pb"

  # Run C++ protoc with --descriptor_set_out
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --descriptor_set_out="$expected_pb" \
    $extra_flags \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go with --descriptor_set_out
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --descriptor_set_out="$actual_pb" \
    $extra_flags \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  # If both succeeded, compare descriptor set binaries
  if [ -f "$result_dir/both_ok.txt" ]; then
    if cmp -s "$expected_pb" "$actual_pb"; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      {
        echo "Descriptor set binary differs"
        echo "expected size: $(wc -c < "$expected_pb") bytes"
        echo "actual size:   $(wc -c < "$actual_pb") bytes"
      } > "$failure_file"
    fi
  fi
}

# -- multi-plugin profile test ---------------------------------------------
# Runs TWO plugins (dump + dump2, same binary) and compares both outputs.

run_multi_plugin_test() {
  local test_name="$1"
  local test_dir="$2"
  local profile_name="$3"
  local full_name="${test_name}@${profile_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local expected1="$result_dir/expected1"
  local actual1="$result_dir/actual1"
  local expected2="$result_dir/expected2"
  local actual2="$result_dir/actual2"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$expected1" "$actual1" "$expected2" "$actual2"

  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # Run C++ protoc with two plugins
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --plugin="protoc-gen-dump2=$PROTOC_GEN_DUMP" \
    --dump_out="$expected1" --dump_opt="$expected1" \
    --dump2_out="$expected2" --dump2_opt="$expected2" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go with two plugins
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --plugin="protoc-gen-dump2=$PROTOC_GEN_DUMP" \
    --dump_out="$actual1" --dump_opt="$actual1" \
    --dump2_out="$actual2" --dump2_opt="$actual2" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  # If both succeeded, compare both plugin outputs
  if [ -f "$result_dir/both_ok.txt" ]; then
    local diff_output=""

    # Compare plugin 1 (dump)
    if [ -f "$expected1/request.pb" ] && [ -f "$actual1/request.pb" ]; then
      if ! cmp -s "$expected1/request.pb" "$actual1/request.pb"; then
        diff_output="Plugin 1 (dump) binary differs"
      fi
    fi

    # Compare plugin 2 (dump2)
    if [ -z "$diff_output" ] && [ -f "$expected2/request.pb" ] && [ -f "$actual2/request.pb" ]; then
      if ! cmp -s "$expected2/request.pb" "$actual2/request.pb"; then
        diff_output="Plugin 2 (dump2) binary differs"
      fi
    fi

    if [ -z "$diff_output" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      echo "$diff_output" > "$failure_file"
    fi
  fi
}

# -- multi-opt profile test ------------------------------------------------
# Tests multiple --dump_opt flags to verify parameter accumulation.

run_multi_opt_test() {
  local test_name="$1"
  local test_dir="$2"
  local profile_name="$3"
  local full_name="${test_name}@${profile_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local expected_dir="$result_dir/expected"
  local actual_dir="$result_dir/actual"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$expected_dir" "$actual_dir"

  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # Run C++ protoc with multiple --dump_opt flags
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$expected_dir" \
    --dump_opt="$expected_dir" \
    --dump_opt=key1=val1 \
    --dump_opt=key2=val2 \
    --dump_opt=flag_only \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go with multiple --dump_opt flags
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$actual_dir" \
    --dump_opt="$actual_dir" \
    --dump_opt=key1=val1 \
    --dump_opt=key2=val2 \
    --dump_opt=flag_only \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  if [ -f "$result_dir/both_ok.txt" ]; then
    # Compare the request JSON to verify parameter field matches
    # The parameter field should show comma-separated accumulated params
    local diff_output=""
    if [ -f "$expected_dir/request.pb" ] && [ -f "$actual_dir/request.pb" ]; then
      if ! cmp -s "$expected_dir/request.pb" "$actual_dir/request.pb"; then
        diff_output="Binary CodeGeneratorRequest differs (multi-opt)"
      fi
    fi

    if [ -z "$diff_output" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      echo "$diff_output" > "$failure_file"
    fi
  fi
}

# -- plugin + descriptor combined profile test -----------------------------
# Runs both a plugin AND --descriptor_set_out in a single invocation.

run_plugin_descriptor_test() {
  local test_name="$1"
  local test_dir="$2"
  local profile_name="$3"
  local full_name="${test_name}@${profile_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local expected_dir="$result_dir/expected"
  local actual_dir="$result_dir/actual"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$expected_dir" "$actual_dir"

  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # Run C++ protoc with plugin + descriptor_set_out
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$expected_dir" --dump_opt="$expected_dir" \
    --descriptor_set_out="$expected_dir/descriptor.pb" \
    --include_imports --include_source_info \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go with plugin + descriptor_set_out
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="$actual_dir" --dump_opt="$actual_dir" \
    --descriptor_set_out="$actual_dir/descriptor.pb" \
    --include_imports --include_source_info \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  if [ -f "$result_dir/both_ok.txt" ]; then
    local diff_output=""

    # Compare plugin output
    if [ -f "$expected_dir/request.pb" ] && [ -f "$actual_dir/request.pb" ]; then
      if ! cmp -s "$expected_dir/request.pb" "$actual_dir/request.pb"; then
        diff_output="Plugin request.pb differs"
      fi
    fi

    # Compare descriptor set output
    if [ -z "$diff_output" ] && [ -f "$expected_dir/descriptor.pb" ] && [ -f "$actual_dir/descriptor.pb" ]; then
      if ! cmp -s "$expected_dir/descriptor.pb" "$actual_dir/descriptor.pb"; then
        diff_output="Descriptor set differs"
      fi
    fi

    if [ -z "$diff_output" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      echo "$diff_output" > "$failure_file"
    fi
  fi
}

# -- colon param syntax profile test ---------------------------------------
# Tests --X_out=PARAM:DIR syntax (parameter passed via _out flag).

run_colon_param_test() {
  local test_name="$1"
  local test_dir="$2"
  local profile_name="$3"
  local full_name="${test_name}@${profile_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local expected_dir="$result_dir/expected"
  local actual_dir="$result_dir/actual"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$expected_dir" "$actual_dir"

  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # The colon syntax: --dump_out=colon_test_param:DIR
  # This passes "colon_test_param" as the parameter to the plugin.
  # protoc-gen-dump uses the parameter as output dir, so we also need --dump_opt
  # to set the actual output dir. The colon param becomes part of the parameter.

  # Run C++ protoc with colon syntax
  local cpp_ok=true
  local cpp_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="colon_test_param:$expected_dir" \
    --dump_opt="$expected_dir" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/cpp_error.txt" || cpp_ok=false
  local cpp_elapsed=$(( $(now_ms) - cpp_start ))
  echo "$cpp_ok" > "$result_dir/cpp_ok.txt"

  # Run Go protoc-go with colon syntax
  local go_ok=true
  local go_start=$(now_ms)
  (cd "$test_dir" && "$PROTOC_GO" \
    --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
    --dump_out="colon_test_param:$actual_dir" \
    --dump_opt="$actual_dir" \
    -I"$PROTOC_INCLUDE" \
    -I. \
    $proto_basenames) 2>"$result_dir/go_error.txt" || go_ok=false
  local go_elapsed=$(( $(now_ms) - go_start ))
  echo "$go_ok" > "$result_dir/go_ok.txt"

  compare_results "$result_dir" "$result_file" "$failure_file" "$cpp_elapsed" "$go_elapsed"

  if [ -f "$result_dir/both_ok.txt" ]; then
    local diff_output=""
    if [ -f "$expected_dir/request.pb" ] && [ -f "$actual_dir/request.pb" ]; then
      if ! cmp -s "$expected_dir/request.pb" "$actual_dir/request.pb"; then
        diff_output="Binary CodeGeneratorRequest differs (colon param)"
      fi
    fi

    if [ -z "$diff_output" ]; then
      echo "PASS $cpp_elapsed $go_elapsed" > "$result_file"
    else
      echo "FAIL $cpp_elapsed $go_elapsed" > "$result_file"
      echo "$diff_output" > "$failure_file"
    fi
  fi
}

# -- CLI error tests -------------------------------------------------------

run_cli_test() {
  local test_name="$1"
  local args="$2"
  local stdin_data="$3"
  local full_name="cli@${test_name}"
  local result_dir="$RESULTS_DIR/$full_name"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"

  mkdir -p "$result_dir"

  # Run C++ protoc
  local cpp_exit=0
  if [ -n "$stdin_data" ]; then
    echo "$stdin_data" | eval "$PROTOC" $args >"$result_dir/cpp_stdout.txt" 2>"$result_dir/cpp_stderr.txt" || cpp_exit=$?
  else
    eval "$PROTOC" $args >"$result_dir/cpp_stdout.txt" 2>"$result_dir/cpp_stderr.txt" || cpp_exit=$?
  fi

  # Run Go protoc-go
  local go_exit=0
  if [ -n "$stdin_data" ]; then
    echo "$stdin_data" | eval "$PROTOC_GO" $args >"$result_dir/go_stdout.txt" 2>"$result_dir/go_stderr.txt" || go_exit=$?
  else
    eval "$PROTOC_GO" $args >"$result_dir/go_stdout.txt" 2>"$result_dir/go_stderr.txt" || go_exit=$?
  fi

  # Compare exit codes
  if [ "$cpp_exit" != "$go_exit" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "exit code mismatch: C++ protoc=$cpp_exit, Go protoc-go=$go_exit"
      echo ""
      echo "--- C++ stderr ---"
      cat "$result_dir/cpp_stderr.txt"
      echo ""
      echo "+++ Go stderr +++"
      cat "$result_dir/go_stderr.txt"
    } > "$failure_file"
    return
  fi

  # Compare stderr (normalized; strip GLOG prefixes from C++ protobuf LOG lines)
  local cpp_stderr go_stderr
  cpp_stderr=$(cat "$result_dir/cpp_stderr.txt" | sed 's/^[EIWF][0-9][0-9][0-9][0-9] [0-9:.]* [0-9]* [^ ]*] //' | sed 's/[[:space:]]*$//' | sed '/^$/d')
  go_stderr=$(cat "$result_dir/go_stderr.txt" | sed 's/[[:space:]]*$//' | sed '/^$/d')

  if [ "$cpp_stderr" != "$go_stderr" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "stderr mismatch (exit code=$cpp_exit)"
      diff -u \
        <(cat "$result_dir/cpp_stderr.txt" | sed 's/^[EIWF][0-9][0-9][0-9][0-9] [0-9:.]* [0-9]* [^ ]*] //' | sed 's/[[:space:]]*$//') \
        <(cat "$result_dir/go_stderr.txt" | sed 's/[[:space:]]*$//') \
        2>&1 || true
    } > "$failure_file"
    return
  fi

  # Compare stdout (normalized; use LC_ALL=C for binary-safe sed)
  local cpp_stdout go_stdout
  cpp_stdout=$(LC_ALL=C cat "$result_dir/cpp_stdout.txt" | LC_ALL=C sed 's/[[:space:]]*$//' | LC_ALL=C sed '/^$/d')
  go_stdout=$(LC_ALL=C cat "$result_dir/go_stdout.txt" | LC_ALL=C sed 's/[[:space:]]*$//' | LC_ALL=C sed '/^$/d')

  if [ "$cpp_stdout" != "$go_stdout" ]; then
    echo "FAIL 0 0" > "$result_file"
    {
      echo "stdout mismatch (exit code=$cpp_exit)"
      diff -u \
        <(LC_ALL=C cat "$result_dir/cpp_stdout.txt" | LC_ALL=C sed 's/[[:space:]]*$//') \
        <(LC_ALL=C cat "$result_dir/go_stdout.txt" | LC_ALL=C sed 's/[[:space:]]*$//') \
        2>&1 || true
    } > "$failure_file"
    return
  fi

  echo "PASS 0 0" > "$result_file"
}

# -- launch all tests ------------------------------------------------------

PIDS=()
TEST_NAMES=()

# Proto file tests: each testdata dir × each profile
for test_dir in "$TESTS_DIR"/*/; do
  if [ -d "$test_dir" ]; then
    test_name="$(basename "$test_dir")"
    for profile_spec in "${PROFILES[@]}"; do
      IFS='|' read -r profile_name profile_mode extra_flags <<< "$profile_spec"
      full_name="${test_name}@${profile_name}"

      case "$profile_mode" in
        plugin)
          run_plugin_test "$test_name" "$test_dir" "$profile_name" "$extra_flags" &
          ;;
        descriptor)
          run_descriptor_test "$test_name" "$test_dir" "$profile_name" "$extra_flags" &
          ;;
        multi_plugin)
          run_multi_plugin_test "$test_name" "$test_dir" "$profile_name" &
          ;;
        multi_opt)
          run_multi_opt_test "$test_name" "$test_dir" "$profile_name" &
          ;;
        plugin_descriptor)
          run_plugin_descriptor_test "$test_name" "$test_dir" "$profile_name" &
          ;;
        colon_param)
          run_colon_param_test "$test_name" "$test_dir" "$profile_name" &
          ;;
      esac

      PIDS+=($!)
      TEST_NAMES+=("$full_name")
    done
  fi
done

