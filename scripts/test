# -- determinism tests -----------------------------------------------------
# Run protoc-go multiple times on select cases and verify byte-identical output.

run_determinism_test() {
  local test_name="$1"
  local test_dir="$2"
  local mode="$3"
  local full_name="determinism@${test_name}_${mode}"
  local result_dir="$RESULTS_DIR/$full_name"
  local result_file="$result_dir/result.txt"
  local failure_file="$result_dir/failure.txt"
  local iterations=5

  mkdir -p "$result_dir"

  local proto_files proto_basenames
  proto_files=$(find "$test_dir" -maxdepth 1 -name "*.proto" | sort)
  if [ -z "$proto_files" ]; then
    echo "PASS 0 0" > "$result_file"
    return
  fi
  proto_basenames=""
  for f in $proto_files; do
    proto_basenames="$proto_basenames $(basename "$f")"
  done

  # Run N times and collect outputs
  for ((i=1; i<=iterations; i++)); do
    local run_dir="$result_dir/run_${i}"
    mkdir -p "$run_dir"

    if [ "$mode" = "plugin" ]; then
      (cd "$test_dir" && "$PROTOC_GO" \
        --plugin="protoc-gen-dump=$PROTOC_GEN_DUMP" \
        --dump_out="$run_dir" \
        --dump_opt="$run_dir" \
        -I"$PROTOC_INCLUDE" \
        -I. \
        $proto_basenames) 2>"$run_dir/stderr.txt" || true
    else
      (cd "$test_dir" && "$PROTOC_GO" \
        --descriptor_set_out="$run_dir/output.pb" \
        --include_imports --include_source_info \
        -I"$PROTOC_INCLUDE" \
        -I. \
        $proto_basenames) 2>"$run_dir/stderr.txt" || true
    fi
  done

  # Compare all runs against run_1
  local ref_dir="$result_dir/run_1"
  local mismatches=""

  for ((i=2; i<=iterations; i++)); do
    local run_dir="$result_dir/run_${i}"
    if [ "$mode" = "plugin" ]; then
      if [ -f "$ref_dir/request.pb" ] && [ -f "$run_dir/request.pb" ]; then
        if ! cmp -s "$ref_dir/request.pb" "$run_dir/request.pb"; then
          mismatches="$mismatches run_1 vs run_${i} (request.pb differs)"
        fi
      fi
    else
      if [ -f "$ref_dir/output.pb" ] && [ -f "$run_dir/output.pb" ]; then
        if ! cmp -s "$ref_dir/output.pb" "$run_dir/output.pb"; then
          mismatches="$mismatches run_1 vs run_${i} (output.pb differs)"
        fi
      fi
    fi
  done

  if [ -z "$mismatches" ]; then
    echo "PASS 0 0" > "$result_file"
  else
    echo "FAIL 0 0" > "$result_file"
    {
      echo "Non-deterministic output detected across $iterations runs:"
      echo "$mismatches"
    } > "$failure_file"
  fi
}

# Run determinism tests on a selection of diverse test cases
DETERMINISM_CASES=(
  "01_basic_message"
  "04_nested"
  "06_map"
  "11_import_public"
  "16_comments"
  "28_proto2_group"
  "329_large_stress"
)

for det_case in "${DETERMINISM_CASES[@]}"; do
  det_dir="$TESTS_DIR/$det_case"
  if [ -d "$det_dir" ]; then
    for det_mode in plugin descriptor; do
      run_determinism_test "$det_case" "$det_dir" "$det_mode" &
      PIDS+=($!)
      TEST_NAMES+=("determinism@${det_case}_${det_mode}")
    done
  fi
done

# Wait for all tests to finish
for pid in "${PIDS[@]}"; do
  wait "$pid" || true
done

# -- collect results ------------------------------------------------------

PASS=0
FAIL=0
ERRORS=""
CPP_TOTAL_MS=0
GO_TOTAL_MS=0

for test_name in $(echo "${TEST_NAMES[@]}" | tr ' ' '\n' | sort); do
  result_file="$RESULTS_DIR/$test_name/result.txt"
  failure_file="$RESULTS_DIR/$test_name/failure.txt"

  if [ ! -f "$result_file" ]; then
    continue
  fi

  read -r status cpp_ms go_ms < "$result_file"
  CPP_TOTAL_MS=$(( CPP_TOTAL_MS + cpp_ms ))
  GO_TOTAL_MS=$(( GO_TOTAL_MS + go_ms ))

  if [ "$status" = "PASS" ]; then
    PASS=$((PASS + 1))
    if [ "$SUMMARY_ONLY" = false ]; then
      echo "PASS $test_name"
    fi
  else
    FAIL=$((FAIL + 1))
    if [ "$SUMMARY_ONLY" = false ]; then
      echo "FAIL $test_name"
      if [ -f "$failure_file" ]; then
        head -40 "$failure_file"
        echo ""
      fi
    fi
    if [ -f "$failure_file" ]; then
      ERRORS="$ERRORS\n--- $test_name ---\n$(cat "$failure_file")"
    fi
  fi
done

# -- summary --------------------------------------------------------------

TOTAL=$((PASS + FAIL))
echo ""
echo "Results: $PASS/$TOTAL passed, $FAIL/$TOTAL failed"

if [ "$CPP_TOTAL_MS" -gt 0 ] && [ "$GO_TOTAL_MS" -gt 0 ]; then
  CPP_SEC=$(echo "scale=1; $CPP_TOTAL_MS / 1000" | bc)
  GO_SEC=$(echo "scale=1; $GO_TOTAL_MS / 1000" | bc)
  echo "Performance: C++ protoc ${CPP_SEC}s, Go protoc-go ${GO_SEC}s"
fi

if [ "$FAIL" -gt 0 ]; then
  if [ "$SUMMARY_ONLY" = true ]; then
    echo ""
    echo "Failing tests:"
    echo -e "$ERRORS" | grep "^--- " | sed 's/^--- /  /' | sed 's/ ---$//'
  fi
  exit 1
fi
